<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (HTTP) traffic is disallowed everywhere. The optional self-update and
  support-diagnostics features (when configured via server.url / r2.base.url) must use HTTPS.
  No certificate pins are configured because there is no fixed server domain; a fork hosting
  its own infrastructure can add a <domain-config> with a <pin-set> here.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
